%------------------
% Items settings
%------------------
\setbeamertemplate{items}[circle]
%------------------
% Text colour settings
%------------------
\usebeamercolor[fg]{normal text}
%------------------
% Background and horizontal line of title page
%------------------
\setbeamertemplate{background}{
\begin{tikzpicture}
%
\ifnum\thepage>1\relax%
% background for pages > 1 
	%\fill[white,opacity=1] (0,0) rectangle(\the\paperwidth,\the\paperheight);
\else
  \useasboundingbox (0,0) rectangle(\the\paperwidth,\the\paperheight);
  % Background image
  \node[opacity=0.1, at=(current page.center)]{\includegraphics[width=\paperwidth]{graphics/Bogota.jpg}};
  % line between logo and title
  \fill[color=UNALGrisClaro] (1,6.4) rectangle(2.5,6.5);  
  \fill[color=UNALRojo] (2.5,6.4) rectangle(5.3,6.5);  
  \fill[color=UNALVerde] (5.3,6.4) rectangle(\the\paperwidth,6.5); 
\fi
% in debug mode, show the grid
\ifdefined\DEBUG
	\draw[help lines,xstep=1,ystep=1,gray] (current page.south west) grid (current page.north east);
\fi
\end{tikzpicture}
}

\newcommand{\rotulo}[1]{\def\insertrotulo{#1}} %%% yesid
\newcommand{\director}[1]{\def\insertdirector{#1}} %%% yesid
\newcommand{\institutedos}[1]{\def\insertinstitutedos{#1}} %%% yesid
%------------------
% Text and logo in title page
%------------------
\defbeamertemplate*{title page}{UNALtitle}[1][]
{
\begin{textblock*}{14cm}(1cm,3cm)
{\usebeamercolor[fg]{title}\usebeamerfont{title}\inserttitle}
\end{textblock*}
%
\begin{textblock*}{14cm}(1cm,4.7cm)
{\usebeamercolor[fg]{subtitle}\usebeamerfont{subtitle}\insertsubtitle}
\end{textblock*}
%
\begin{textblock*}{14cm}(9.9cm,6.5cm)
{\usebeamercolor[fg]{rotulo}\usebeamerfont{rotulo}\insertrotulo}
\end{textblock*}
%
\begin{textblock*}{14cm}(9.9cm,7cm)
{\usebeamercolor[fg]{director}\usebeamerfont{author}\insertdirector}
\end{textblock*}
%
\begin{textblock*}{14cm}(9.9cm,7.5cm)
{\usebeamercolor[fg]{institutedos}\usebeamerfont{institutedos}\insertinstitutedos}
\end{textblock*}
%
\begin{textblock*}{14cm}(6.6cm,8.2cm)
{\usebeamercolor[fg]{date}\usebeamerfont{date}\insertdate}
\end{textblock*}
%
%
\begin{textblock*}{14cm}(1cm,7cm)
{\usebeamercolor[fg]{author}\usebeamerfont{author}\insertauthor}
\end{textblock*}
%
\begin{textblock*}{14cm}(1cm,7.5cm)
{\usebeamercolor[fg]{institute}\usebeamerfont{institute}\insertinstitute}
\end{textblock*}
%
\begin{tikzpicture}[overlay,remember picture]
\node[inner sep=0pt] at (2.1,2.5){
   \includegraphics[width=5cm]{graphics/UNAL_colortext.png}
};
\end{tikzpicture}
}
